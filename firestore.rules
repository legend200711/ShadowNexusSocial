rules_version = '2';

//
// Shadow Nexus Social — Firestore Security Rules
//
// Collections used by this app:
//   /users/{uid}                                      — user profiles
//   /stories/{storyId}                                — posts
//   /posts/{postId}                                   — posts
//   /siteSettings/{doc}                               — site config (maintenance mode, feature flags)
//

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isFounder() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'founder';
    }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{uid} {
      // Anyone signed in can read any profile (needed for notifications, guest info)
      allow read: if isSignedIn();
      // Only the account owner can write their own profile
      allow write: if isOwner(uid);
    }

    // ── Stories ───────────────────────────────────────────────────────────────

    match /stories/{storyId} {
      // Any signed-in user can read a story
      allow read: if isSignedIn();
      // Anyone signed in can create
      allow create: if isSignedIn();
      // Any signed-in user can update
      allow update: if isSignedIn();
      // Only the author can delete
      allow delete: if isSignedIn() && resource.data.authorUid == request.auth.uid;
    }

    // ── Posts ─────────────────────────────────────────────────────────────────

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.authorUid == request.auth.uid;
    }

    // ── Site settings (maintenance mode, feature flags) ───────────────────────
    // Anyone signed in may read (needed for maintenance check on load).
    // Only the Founder may write.

    match /siteSettings/{docId} {
      allow read: if isSignedIn();
      allow write: if isFounder();
    }

    // ── AI Moderation Log ─────────────────────────────────────────────────────
    // Any signed-in user can create log entries (written by the client AI engine).
    // Only the Founder can read or delete entries.

    match /aiModerationLog/{docId} {
      allow create: if isSignedIn();
      allow read, delete: if isFounder();
      allow update: if false;
    }

    // ── Reports ───────────────────────────────────────────────────────────────
    // Any signed-in user can file a report (human or AI).
    // Founder / staff can read and update.

    match /reports/{docId} {
      allow create: if isSignedIn();
      allow read, update: if isFounder();
      allow delete: if isFounder();
    }

    // ── Audit Log ─────────────────────────────────────────────────────────────
    match /auditLog/{docId} {
      allow create: if isSignedIn();
      allow read: if isFounder();
      allow update, delete: if false;
    }

    // ── AI Toggle Log ─────────────────────────────────────────────────────────
    match /aiToggleLog/{docId} {
      allow create: if isFounder();
      allow read: if isFounder();
      allow update, delete: if false;
    }

    // ── Announcements ─────────────────────────────────────────────────────────
    match /announcements/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isFounder();
    }

  }
}
